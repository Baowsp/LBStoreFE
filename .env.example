# =========================================================================
# LBStore Frontend Environment Variables Template
# Copy this file to a '.env' file in your local development or configure
# this variable in Vercel Dashboard -> Settings -> Environment Variables.
# =========================================================================

# The base URL of your backend API (no trailing slash)
# Production example: VITE_API_BASE_URL=http://123.45.67.89:8080/api
# Or: VITE_API_BASE_URL=https://your-backend-domain.com/api
VITE_API_BASE_URL=http://localhost:8080/api
